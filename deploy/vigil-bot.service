[Unit]
Description=Vigil Telegram command bot
After=network-online.target
[Service]
User=__USER__
WorkingDirectory=__HOME__/Vigil
Environment=KRONOS_REPO_PATH=__HOME__/Kronos
Environment=KRONOS_DEVICE=cpu
ExecStart=__HOME__/Vigil/.venv/bin/python -m scanner.telegram_bot
Restart=always
RestartSec=10
[Install]
WantedBy=multi-user.target
