# Copy to .env and fill in. Never commit .env.

# ─── LLM synthesis provider ────────────────────────────────────────────────
# Which model writes the research reports. One of: gemini | anthropic | none
#   gemini    = Google AI Studio free tier (default, no cost)
#   anthropic = Claude (stronger synthesis, paid)
#   none      = deterministic template report, no API key needed
LLM_PROVIDER=gemini

# Gemini (free tier key from https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── Fundamentals source ───────────────────────────────────────────────────
# auto = FMP if FMP_API_KEY set, else free Yahoo. Get a free key at
# https://site.financialmodelingprep.com/ (250 req/day) for history + sector data.
FUNDAMENTALS_PROVIDER=auto
FMP_API_KEY=


# Anthropic (only needed if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6
ANTHROPIC_USE_SONNET=false        # true => claude-sonnet-4-6 (cheaper)

# ─── OpenAlice MCP (market data source) ────────────────────────────────────
# Default matches OpenAlice's `pnpm dev` MCP endpoint. Ports auto-bump if taken
# read the URL the OpenAlice terminal actually printed.
OPENALICE_MCP_URL=http://localhost:47332/mcp
OPENALICE_BACKEND_URL=http://localhost:47331
OPENALICE_DIR=~/OpenAlice              # used by Vigil Full Stack.command
VIGIL_START_OPENALICE=true             # false = only start Vigil, reuse existing OpenAlice
VIGIL_WARM_KRONOS=false                # true = load Kronos at launch; false = on first forecast

# ─── Kronos forecasting service ────────────────────────────────────────────
KRONOS_SERVICE_PORT=8765
KRONOS_MODEL=NeoQuasar/Kronos-base   # base=102.3M (largest public). small=24.7M lighter; large=499M unreleased
KRONOS_TOKENIZER=NeoQuasar/Kronos-Tokenizer-base
KRONOS_REPO_PATH=~/Kronos            # path to the cloned Kronos source tree
KRONOS_SAMPLE_COUNT=3
KRONOS_MC_PATHS=24                   # default MC paths; override per scan in the UI
KRONOS_DEVICE=auto                   # auto | cpu | mps | cuda:0
# Optional remote Kronos service, e.g. http://host:8765
KRONOS_SERVICE_URL=

# ─── Scanner behaviour ─────────────────────────────────────────────────────
# ─── Position sizing (advisory) ────────────────────────────────────────────
VIGIL_ACCOUNT_EQUITY=0               # your account size; 0 = show weights only, no $ amounts
SIZING_KELLY_FRACTION=0.5            # fraction of full Kelly (0.5 = half-Kelly)
SIZING_TARGET_VOL=0.15              # annualized vol target per position

DEFAULT_LOOKBACK=400                 # candles of history fed to Kronos
DEFAULT_PRED_LEN=60     # only a fallback/secondary horizon; picks use KRONOS_HORIZONS auto-select
KRONOS_HORIZONS=10,30,60        # system auto-selects the operative one per opportunity                  # default forecast candles; override per scan in the UI
MAX_UNIVERSE_SIZE=700                # cap before screen; high enough for full index components
MAX_INDEX_COMPONENTS_LOCAL=120       # local safety cap for index scans; 0 = uncapped
MAX_SCREENED_SIZE=30                 # cap before Kronos (inference cost control)
MAX_WATCHLIST_SIZE=10                # names in final output

# ─── UI ────────────────────────────────────────────────────────────────────
SCANNER_UI_PORT=8080
# A random secret; the worker requires it (X-Vigil-Token header) so an open port
# isn't free compute for the world. setup-oracle.sh auto-generates one.
VIGIL_WORKER_TOKEN=
VIGIL_WORKER_URL=          # set to your cloud worker (e.g. http://VM-IP:8090) -> Mac becomes a pure client
VIGIL_WORKER_PORT=8090               # remote worker API port
VIGIL_REFRESH_ON_OPEN=false          # true = run SIGNAL_MARKETS when app starts

# ─── Telegram signals (free; works on iPhone) ─────────────────────────────
# Create a bot via @BotFather, then message it once and get your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SIGNAL_MIN_CONVICTION=4          # send picks at/above this conviction
SIGNAL_MIN_RETURN=6              # ...or with |expected return %| at/above this
SIGNAL_MARKETS=global-liquid

# ─── Free OHLCV fallback ──────────────────────────────────────────────────
# When OpenAlice returns no price history, fetch from Stooq (no key needed).
# Lets index/crypto scans run without OpenAlice (e.g. in CI / 24-7).
USE_DATA_FALLBACK=true
